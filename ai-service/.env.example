# AI Service Environment Configuration
# Copy this to .env and adjust as needed

# Port must match PYTHON_AI_PORT in ../config/ports.config.js
PYTHON_AI_PORT=5000

# Model storage
MODELS_DIR=./models

# Logging
LOG_LEVEL=INFO

# Development mode
DEBUG=false

# Node.js backend URL (for callbacks if needed)
NODE_BACKEND_URL=http://localhost:8080
