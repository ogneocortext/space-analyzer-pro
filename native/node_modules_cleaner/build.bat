@echo off
echo Building node_modules_cleaner...

REM Set up environment
set PATH=%USERPROFILE%\.cargo\bin;%PATH%
set RUSTUP_TOOLCHAIN=stable-x86_64-pc-windows-msvc

REM Try to build with existing scanner's approach
cd /d "%~dp0"

echo Using cargo build...
cargo build --release

if %ERRORLEVEL% EQU 0 (
    echo Build successful!
    echo Executable: target\release\node_modules_cleaner.exe
    copy target\release\node_modules_cleaner.exe ..\..\bin\ 2>nul
) else (
    echo Build failed. You can use the existing space-analyzer.exe for node_modules analysis:
    echo   native\scanner\target\release\space-analyzer.exe "path\to\project" --output analysis.json
)

pause
