# =============================================================================
# Space Analyzer Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# ⚠️  NEVER commit .env files to version control! ⚠️
# This file is already in .gitignore to prevent accidental commits.
#
# SECURITY BEST PRACTICES:
# - Keep API keys secret and rotate them regularly
# - Use localhost-only mode when possible (OLLAMA_CLOUD_ENABLED=false)
# - Never share your .env file with anyone
# - Use separate API keys for development vs production
# =============================================================================

# ============================================
# OLLAMA (Local AI) - Required for localhost
# ============================================

# URL of your local Ollama instance (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Default model to use for local inference (optimized for coding)
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b-instruct

# Request timeout in milliseconds (30 seconds)
OLLAMA_TIMEOUT_MS=30000

# ============================================
# OLLAMA CLOUD (Optional)
# ============================================
# ⚠️  Enabling cloud features will consume your Ollama Cloud quota!
# Set to "false" for localhost-only operation (recommended)

# Enable Ollama Cloud features: "true" or "false"
OLLAMA_CLOUD_ENABLED=false

# API key for Ollama Cloud (only needed if OLLAMA_CLOUD_ENABLED=true)
# Get your key at: https://ollama.com/settings
# OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key_here

# ============================================
# EXTERNAL AI PROVIDERS (Optional)
# ============================================
# These are only needed if you want to use external AI providers
# alongside or instead of local Ollama

# OpenAI API key (for GPT-based features)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_openai_key_here

# Anthropic API key (for Claude-based features)
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Google GenAI API key (for Gemini features)
# Get your key at: https://makersuite.google.com/app/apikey
# GOOGLE_GENAI_API_KEY=your_google_genai_key_here

# ============================================
# WEB SEARCH APIs (Optional - for local web search tools)
# ============================================
# Configure these to enable web search tools that run locally
# These are alternatives to Ollama Cloud's web search

# Serper API (Google Search API) - https://serper.dev/
# Free tier: 2,500 searches/month
# SERPER_API_KEY=your_serper_api_key_here

# Bing Search API - https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
# Free tier: 1,000 searches/month
# BING_SEARCH_API_KEY=your_bing_search_api_key_here

# Tavily AI Search - https://tavily.com/
# Free tier: 1,000 API calls/month
# TAVILY_API_KEY=tvly-your_tavily_api_key_here

# ============================================
# CLOUD STORAGE (Optional - for backup/sync)
# ============================================

# AWS S3 (for backup storage)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Azure Blob Storage (for backup storage)
# AZURE_STORAGE_KEY=your_azure_storage_key

# ============================================
# SECURITY (Auto-generated if not set)
# ============================================
# These are used for encryption and authentication
# If not set, the app will auto-generate secure random values

# Encryption key for sensitive data (32+ characters recommended)
# ENCRYPTION_KEY=your_32_character_encryption_key_here

# JWT secret for authentication (32+ characters recommended)
# JWT_SECRET=your_32_character_jwt_secret_here

# ============================================
# APPLICATION SETTINGS
# ============================================

# Environment mode: development, production, or test
NODE_ENV=development

# Backend API Server Port (must match API_SERVER_PORT in config/ports.config.js)
PORT=8080

# Frontend Development Server Port (must match VITE_DEV_PORT in config/ports.config.js)
VITE_DEV_PORT=5173

# =============================================================================
# IMPORTANT REMINDERS
# =============================================================================
# 1. After editing, rename this file to .env (remove the .example extension)
# 2. The .env file is already in .gitignore - it will NOT be committed
# 3. For team development, share this .env.example template only
# 4. Each developer should create their own .env with their own API keys
# 5. Use localhost-only mode (OLLAMA_CLOUD_ENABLED=false) when possible
# 6. Rotate API keys regularly, especially if you suspect exposure
# =============================================================================
