# Space Analyzer Pro - Environment Variables
# Copy to .env and fill in your values

# === Unified AI Service ===
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=5000
AI_SERVICE_DEBUG=false

# === Ollama ===
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=phi4-mini:latest
OLLAMA_TIMEOUT=300
OLLAMA_MAX_RETRIES=3

# === Security (REQUIRED in production) ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
API_KEY=

# === Auth ===
ENABLE_AUTH=true
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === Feature Flags ===
ENABLE_ML_CATEGORIZER=true
ENABLE_OLLAMA=true

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8091

# === ML Model Paths ===
MODEL_DIR=ml_categorizer/models
