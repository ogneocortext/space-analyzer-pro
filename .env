NODE_ENV=development

# Backend API Server Port (must match API_SERVER_PORT in config/ports.config.js)
PORT=8080

# Frontend Development Server Port (must match VITE_DEV_PORT in config/ports.config.js)
VITE_DEV_PORT=5173

OLLAMA_HOST=http://localhost:11434
OLLAMA_NUM_CTX=16384
LOG_LEVEL=info

# Frontend environment variables (VITE_* are exposed to browser)
VITE_OLLAMA_NUM_CTX=16384
VITE_FRAMEWORK=vue
VITE_APP_NAME=Space Analyzer Pro
VITE_APP_VERSION=2.8.3
VITE_API_URL=http://localhost:8080/api
VITE_OLLAMA_HOST=http://localhost:11434
VITE_NODE_ENV=development

# Backend API URL configuration
# For client-side (Vite): VITE_BACKEND_API_URL=http://localhost:8080/api
# For server-side: BACKEND_API_URL=http://localhost:8080/api
# If not set, client-side will use Vite proxy (/api)
