{
  "info": {
    "name": "Space Analyzer API Collection",
    "description": "API tests for Space Analyzer backend",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has status field', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('status');",
              "});",
              "",
              "pm.test('Response time is less than 1000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get AI Models",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/ai/models",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "ai", "models"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is array', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});",
              "",
              "pm.test('Each model has required fields', function () {",
              "    const jsonData = pm.response.json();",
              "    jsonData.forEach(model => {",
              "        pm.expect(model).to.have.property('id');",
              "        pm.expect(model).to.have.property('name');",
              "        pm.expect(model).to.have.property('status');",
              "    });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Start Scan",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"path\": \"/test/directory\",\n  \"options\": {\n    \"recursive\": true,\n    \"includeHidden\": false\n  }\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/scan/start",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "scan", "start"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200 or 202', function () {",
              "    pm.expect([200, 202]).to.include(pm.response.code);",
              "});",
              "",
              "pm.test('Response has scan ID', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('scanId');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Scan Status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/scan/{{scanId}}/status",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "scan", "{{scanId}}", "status"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has status field', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('status');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Analysis Results",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/analysis/{{scanId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "analysis", "{{scanId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has analysis data', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('totalSize');",
              "    pm.expect(jsonData).to.have.property('fileCount');",
              "    pm.expect(jsonData).to.have.property('directoryCount');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "scanId",
      "value": "test-scan-123"
    }
  ]
}