                const prompt = this.buildOllamaPrompt(analysisData, query || "Provide comprehensive storage insights");
                const response = await this.queryOllamaWithModel(prompt, this.config.defaultModel);
                
                this.selfLearning.addQA('insights', response, cacheKey, this.config.defaultModel);
                
                res.json({ success: true, insights: response });
