{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Space Analyzer Codemap Shared Schema",
  "description": "Shared schema and common patterns for codemap files",
  "version": "1.0.0",
  "commonPatterns": {
    "component": {
      "type": "object",
      "properties": {
        "file": { "type": "string" },
        "purpose": { "type": "string" },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "features": { "type": "array", "items": { "type": "string" } },
        "props": { "type": "object" },
        "events": { "type": "array", "items": { "type": "string" } },
        "subcomponents": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["file", "purpose"]
    },
    "service": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "purpose": { "type": "string" },
        "methods": { "type": "array", "items": { "type": "string" } },
        "features": { "type": "array", "items": { "type": "string" } },
        "backends": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["path", "purpose"]
    },
    "composable": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "purpose": { "type": "string" },
        "returns": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["path", "purpose"]
    },
    "testing": {
      "type": "object",
      "properties": {
        "unit": { "type": "array", "items": { "type": "string" } },
        "integration": { "type": "array", "items": { "type": "string" } },
        "e2e": { "type": "array", "items": { "type": "string" } },
        "load": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "commonDependencies": {
    "vue": ["vue", "vue-router", "pinia"],
    "ui": ["tailwindcss", "lucide-vue-next"],
    "testing": ["vitest", "@vue/test-utils", "playwright"],
    "ai": ["@ai-sdk/openai", "ollama"],
    "build": ["vite", "typescript", "esbuild"]
  },
  "commonPaths": {
    "components": "src/components/",
    "services": "src/services/",
    "composables": "src/composables/",
    "store": "src/store/",
    "utils": "src/utils/",
    "types": "src/types/",
    "server": "server/",
    "tests": "tests/"
  }
}