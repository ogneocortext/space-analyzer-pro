{
  "name": "space-analyzer-pro",
  "version": "2.1.0",
  "description": "AI-Powered Space Analyzer with Vision Analysis and Feature Hub",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:no-browser": "cross-env BROWSER=none vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint src/main.tsx src/App.tsx --report-unused-disable-directives",
    "server": "cd server && node backend-server.js",
    "server:dev": "cd server && node backend-server.js",
    "start": "node start-all.js",
    "launch": "node launch-services.js",
    "launch:backend": "npm run server:dev",
    "launch:frontend": "npm run dev:no-browser",
    "vision-test": "node direct-vision-test.js",
    "model-test": "node test-all-models.js",
    "google-test": "node integrated-ollama-puppeteer-test.cjs",
    "port:detect": "node port-config.cjs detect",
    "port:update": "node port-config.cjs update",
    "port:status": "node port-config.cjs status",
    "port:clear": "node port-config.cjs clear",
    "type-check": "tsc -p tsconfig.node.json --noEmit",
    "type-check:full": "tsc --noEmit",
    "update-deps": "npm update && npm audit fix"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-query-devtools": "^5.100.1",
    "@tanstack/react-virtual": "^3.13.24",
    "cmdk": "^1.1.1",
    "comlink": "^4.4.2",
    "commander": "^14.0.3",
    "compression": "^1.8.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "framer-motion": "^12.38.0",
    "helmet": "^8.1.0",
    "kbar": "^0.1.0-beta.48",
    "lucide-react": "^1.11.0",
    "playwright": "^1.59.1",
    "puppeteer": "^24.42.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-force-graph-3d": "^1.29.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "sqlite3": "^6.0.1",
    "three": "^0.184.0",
    "three-forcegraph": "^1.43.4",
    "walkdir": "^0.4.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@browsermcp/mcp": "^0.1.3",
    "@eslint/js": "^10.0.1",
    "@napi-rs/cli": "^3.6.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
