{
  "name": "space-analyzer-pro",
  "version": "2.1.7",
  "description": "AI-Powered Space Analyzer with Vision Analysis and Feature Hub",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:no-browser": "cross-env BROWSER=none vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/main.ts src/App.vue --report-unused-disable-directives",
    "server": "cd server && node backend-server.js",
    "server:dev": "cd server && node backend-server.js",
    "start": "node scripts/start-all.js",
    "launch": "node scripts/launch-services.js",
    "launch:backend": "npm run server:dev",
    "launch:frontend": "npm run dev:no-browser",
    "vision-test": "node scripts/direct-vision-test.js",
    "model-test": "node scripts/test-all-models.js",
    "google-test": "node scripts/integrated-ollama-puppeteer-test.cjs",
    "port:detect": "node scripts/port-config.js detect",
    "port:update": "node scripts/port-config.js update",
    "port:status": "node scripts/port-config.js status",
    "port:clear": "node scripts/port-config.js clear",
    "cleanup:results": "node scripts/cleanup-results.js",
    "type-check": "tsc -p tsconfig.node.json --noEmit",
    "type-check:full": "tsc --noEmit",
    "update-deps": "npm update && npm audit fix",
    "prepare": "husky",
    "github:nav": "node github-nav.js"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "comlink": "^4.4.2",
    "commander": "^14.0.3",
    "compression": "^1.8.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "puppeteer": "^24.42.0",
    "sonner": "^2.0.7",
    "sqlite3": "^6.0.1",
    "three": "^0.184.0",
    "three-forcegraph": "^1.43.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "walkdir": "^0.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@browsermcp/mcp": "^0.1.3",
    "@eslint/js": "^10.0.1",
    "@napi-rs/cli": "^3.6.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.9",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
