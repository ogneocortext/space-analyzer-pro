{
  "name": "space-analyzer-pro",
  "version": "2.8.9",
  "description": "AI-Powered Space Analyzer with ML Categorization and Intelligent Caching",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:no-browser": "cross-env BROWSER=none vite",
    "dev:stable": "vite",
    "dev:original": "vite --config vite.config.original.ts",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "test": "vitest",
    "test:e2e": "node scripts/run-playwright-tests.js",
    "test:e2e:smoke": "node scripts/run-playwright-tests.js smoke",
    "test:e2e:regression": "node scripts/run-playwright-tests.js regression",
    "test:e2e:accessibility": "node scripts/run-playwright-tests.js accessibility",
    "test:e2e:performance": "node scripts/run-playwright-tests.js performance",
    "test:e2e:mobile": "node scripts/run-playwright-tests.js mobile",
    "test:e2e:security": "node scripts/run-playwright-tests.js security",
    "test:e2e:all": "node scripts/run-playwright-tests.js all",
    "test:e2e:debug": "node scripts/run-playwright-tests.js --debug",
    "test:e2e:headed": "node scripts/run-playwright-tests.js --headed",
    "test:e2e:firefox": "node scripts/run-playwright-tests.js --browser firefox",
    "test:e2e:webkit": "node scripts/run-playwright-tests.js --browser webkit",
    "test:e2e:allure": "node scripts/run-playwright-tests.js --reporter=allure",
    "test:e2e:parallel": "node scripts/run-playwright-tests.js --workers=4",
    "test:component": "vitest --environment=jsdom",
    "test:api": "newman run tests/api/space-analyzer-api.collection.json",
    "test:load": "artillery run tests/load/load-test.yml",
    "test:visual": "node scripts/run-visual-tests.js",
    "test:accessibility": "node scripts/run-accessibility-tests.js",
    "test:security": "node scripts/run-security-tests.js",
    "report:allure": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "report:coverage": "vitest --coverage",
    "lint": "eslint src/main.ts src/App.vue --report-unused-disable-directives",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,vue,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,vue,json,css,md}\"",
    "server": "cd server && cross-env NODE_OPTIONS=\"--allow-net=*\" node server-improved.js",
    "server:dev": "cd server && cross-env NODE_OPTIONS=\"--allow-net=*\" node server-improved.js",
    "server:26": "cd server && nvm use 26 && node server.js",
    "server:old": "cd server && cross-env NODE_OPTIONS=\"--allow-net=*\" node controllers/backend-server.js",
    "start": "cross-env NODE_COMPILE_CACHE_PORTABLE=1 NODE_OPTIONS=\"--allow-net=*\" node scripts/start-all-fixed.js",
    "start:optimized": "node scripts/optimize-startup.js",
    "status": "node scripts/status-check.js",
    "launch": "node scripts/launch-services.js",
    "launch:backend": "npm run server:dev",
    "launch:frontend": "npm run dev:no-browser",
    "launch:26": "concurrently \"npm run server:26\" \"npm run dev:no-browser\"",
    "vision-test": "node scripts/direct-vision-test.js",
    "model-test": "node scripts/test-all-models.js",
    "google-test": "node scripts/integrated-ollama-puppeteer-test.cjs",
    "port:detect": "node scripts/port-config.js detect",
    "port:update": "node scripts/port-config.js update",
    "port:status": "node scripts/port-config.js status",
    "port:clear": "node scripts/port-config.js clear",
    "cleanup:results": "node scripts/cleanup-results.js",
    "test:self-learning": "node scripts/test-self-learning.js",
    "test:3d-browser": "node scripts/test-3d-browser.js",
    "test:ntfs-mft": "node scripts/test-ntfs-mft.js",
    "test:usn-journal": "node scripts/test-usn-journal.js",
    "test:advanced-features": "npm run test:self-learning && npm run test:3d-browser && npm run test:ntfs-mft && npm run test:usn-journal",
    "type-check": "tsc -p tsconfig.node.json --noEmit",
    "type-check:full": "tsc --noEmit",
    "update-deps": "npm update && npm audit fix",
    "prepare": "husky",
    "github:nav": "node config/github-nav.js",
    "ai:start": "cd ai-service && powershell -ExecutionPolicy Bypass -File start.ps1",
    "ai:start:unix": "cd ai-service && bash start.sh",
    "ai:install": "cd ai-service && python -m pip install -r requirements.txt",
    "ai:test": "cd ai-service && python test_api.py"
  },
  "dependencies": {
    "@sentry/core": "^10.52.0",
    "@tauri-apps/api": "^2.0.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "comlink": "^4.4.2",
    "commander": "^14.0.3",
    "d3": "^7.9.0",
    "esbuild": "^0.28.0",
    "jspdf": "^4.2.1",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "puppeteer": "^24.42.0",
    "three": "^0.184.0",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@sentry/tracing": "^7.120.4",
    "@sentry/vue": "^10.52.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=26.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "ip-address": "^10.2.0"
  }
}
